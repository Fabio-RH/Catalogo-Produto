generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Categoria {
  idCategoria        Int       @id @default(autoincrement()) @map("id_categoria")
  nomeCategoria      String    @map("nome_categoria")
  descricaoCategoria String?   @map("descricao_categoria")

  produtos           Produto[]

  @@map("categoria")
}

model Estoque {
  idEstoque               Int       @id @default(autoincrement()) @map("id_estoque")
  quantidadeEstoque       Int       @map("quantidade_estoque")
  disponibilidadeEstoque  String    @map("disponibilidade_estoque")

  produtos                Produto[]

  @@map("estoque")
}

model Produto {
  idProduto      Int       @id @default(autoincrement()) @map("id_produto")
  nomeProduto    String    @map("nome_produto")
  precoProduto   Float     @map("preco_produto")

  urlImagem      String?   @map("url_imagem")

  categoriaId    Int?      @map("categoria_id_categoria")
  estoqueId      Int?      @map("estoque_id_estoque")

  categoria      Categoria? @relation(fields: [categoriaId], references: [idCategoria])
  estoque        Estoque?   @relation(fields: [estoqueId], references: [idEstoque])

  @@map("produto")
}